<script>
  (function () {
    var t = document.getElementById("rTicket"),
        l = document.getElementById("rLeads"),
        c = document.getElementById("rClose");
    function fmt(n) { return "$" + Math.round(n).toLocaleString(); }
    function render() {
      document.getElementById("rTicketV").textContent = fmt(t.value);
      document.getElementById("rLeadsV").textContent = l.value;
      document.getElementById("rCloseV").textContent = c.value + "%";
      var monthly = l.value * (c.value / 100) * t.value;
      var big = document.getElementById("rMonthly");
      big.innerHTML = "";
      big.appendChild(document.createTextNode(fmt(monthly)));
      var span = document.createElement("span"); span.textContent = "/month";
      big.appendChild(span);
      document.getElementById("rYearly").textContent = fmt(monthly * 12);
    }
    [t, l, c].forEach(function (s) { s.addEventListener("input", render); });
    render();
  })();

  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) { if (e.isIntersecting) e.target.classList.add("visible"); });
  }, { threshold: 0.1 });
  document.querySelectorAll(".fade-in").forEach(function (el) { observer.observe(el); });
</script>
