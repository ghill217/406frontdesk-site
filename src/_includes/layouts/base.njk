<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  {# ---- SEO ---- #}
  <title>{{ title }}{% if title %} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description }}" />
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  {% if noindex %}<meta name="robots" content="noindex, follow" />{% endif %}

  {# ---- Open Graph / social ---- #}
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:site_name" content="{{ site.name }}" />
  <meta property="og:title" content="{{ ogTitle or title or site.name }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:image" content="{{ site.url }}{{ ogImage or site.ogImage }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle or title or site.name }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or site.ogImage }}" />

  {# ---- Icons ---- #}
  <link rel="icon" type="image/png" sizes="192x192" href="/assets/img/favicon.png?v=2" />
  <link rel="apple-touch-icon" sizes="512x512" href="/assets/img/apple-touch-icon.png" />

  {# ---- Fonts ---- #}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />

  {# ---- Page styles ---- #}
  {% if pageCss %}<link rel="stylesheet" href="/css/{{ pageCss }}.css" />{% endif %}
  <link rel="stylesheet" href="/css/a11y.css" />

  {# ---- Structured data: LocalBusiness ---- #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "406 Front Desk",
    "legalName": "406 Front Desk LLC",
    "url": "https://406frontdesk.com",
    "telephone": "+14068400404",
    "email": "admin@406frontdesk.com",
    "areaServed": "Flathead Valley, Montana",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Kalispell",
      "addressRegion": "MT",
      "addressCountry": "US"
    },
    "description": "AI receptionist for local service businesses — answers calls, texts, and chats 24/7, books appointments, and follows up automatically.",
    "priceRange": "$$",
    "slogan": "Always Answering",
    "foundingDate": "2026",
    "founder": { "@type": "Person", "name": "Gus Hill" },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    }
  }
  </script>
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>
{% include "partials/header.njk" %}

<main id="main">
{{ content | safe }}
</main>

{% include "partials/footer.njk" %}

{# GHL chat widget — site-wide, loaded async so it never blocks first paint #}
<script src="https://widgets.leadconnectorhq.com/loader.js" data-resources-url="https://widgets.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="{{ site.chatWidgetId }}" async></script>
{# Call CTA, bottom-left (chat widget owns bottom-right) — a real phone call demos the AI receptionist
   with every capability incl. transfers, which GHL web-call widgets don't support #}
<a href="tel:{{ site.phone }}" class="call-cta" aria-label="Call the AI receptionist live at {{ site.phoneDisplay }}">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"/></svg>
  <span>Hear it live — {{ site.phoneDisplay }}</span>
</a>
<style>
.call-cta{position:fixed;bottom:20px;left:20px;z-index:9990;display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 1.15rem;border-radius:999px;background:#E8A435;color:#0F2540;font-weight:700;font-size:.95rem;text-decoration:none;box-shadow:0 4px 14px rgba(15,37,64,.35);transition:transform .15s ease,box-shadow .15s ease}
.call-cta:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(15,37,64,.45)}
</style>
</body>
</html>
