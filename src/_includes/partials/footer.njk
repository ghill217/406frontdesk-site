{# ============================================================
   406 FRONT DESK — REUSABLE FOOTER
   Single source of truth. Links come from _data/site.json.
   ============================================================ #}
<style>
  .fd406-footer, .fd406-footer * { box-sizing: border-box; }
  .fd406-footer {
    background: #0F2540; padding: 52px 40px 40px;
    font-family: 'DM Sans', system-ui, sans-serif; width: 100%;
  }
  .fd406-footer-inner {
    max-width: 1040px; margin: 0 auto;
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 40px 64px; flex-wrap: wrap;
  }
  .fd406-footer-brand { flex: 0 0 auto; }
  .fd406-footer-lockup { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 6px; text-decoration: none; }
  .fd406-footer-lockup svg { display: block; }
  .fd406-footer-wordmark {
    font-size: 20px; font-weight: 600; color: #fff; letter-spacing: -0.3px; line-height: 1;
  }
  .fd406-footer-tagline {
    display: block; font-size: 10px; font-weight: 400; color: rgba(255,255,255,0.62);
    letter-spacing: 1.4px; text-transform: uppercase;
  }
  .fd406-footer-groups { display: flex; gap: 48px; flex-wrap: wrap; }
  .fd406-footer-col { display: flex; flex-direction: column; gap: 9px; }
  .fd406-footer-heading {
    font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    color: rgba(255,255,255,0.5); margin-bottom: 3px;
  }
  .fd406-footer-col a {
    color: rgba(255,255,255,0.66); font-size: 13px; text-decoration: none; transition: color 0.2s;
  }
  .fd406-footer-col a:hover { color: #E8A435; }
  .fd406-footer-legal {
    max-width: 1040px; margin: 36px auto 0; color: rgba(255,255,255,0.5);
    font-size: 12px; line-height: 1.6;
  }
  @media (max-width: 720px) {
    .fd406-footer { padding: 40px 24px 32px; text-align: center; }
    .fd406-footer-inner { flex-direction: column; align-items: center; gap: 32px; }
    .fd406-footer-groups { justify-content: center; gap: 32px 40px; }
    .fd406-footer-col { align-items: center; }
    .fd406-footer-legal { text-align: center; }
  }
</style>

<footer class="fd406-footer">
  <div class="fd406-footer-inner">
  <div class="fd406-footer-brand">
