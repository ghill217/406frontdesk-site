{# ============================================================
   406 FRONT DESK — REUSABLE HEADER / NAV
   Single source of truth. Links come from _data/site.json.
   ============================================================ #}
<style>
  .fd406-nav, .fd406-nav *, .fd406-mobile-menu, .fd406-mobile-menu * { box-sizing: border-box; }
  .fd406-nav {
    position: sticky; top: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 40px;
    background: rgba(247,247,245,0.88);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid #e2e3e6;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .fd406-nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
  .fd406-nav-logo-mark { height: 30px; width: auto; display: flex; align-items: center; }
  .fd406-nav-logo-mark img { height: 30px; width: auto; display: block; }
  .fd406-nav-logo-text { font-size: 16px; font-weight: 600; color: #13202E; letter-spacing: -0.3px; }
  .fd406-nav-logo-sub {
    font-size: 11px; font-weight: 400; color: #6b7280; letter-spacing: 0.8px;
    text-transform: uppercase; display: block; line-height: 1; margin-top: 1px;
  }
  .fd406-nav-right { display: flex; align-items: center; gap: 28px; }
  .fd406-nav-links { display: flex; align-items: center; gap: 26px; }
  .fd406-nav-links a {
    text-decoration: none; color: #4b5563; font-size: 14px; font-weight: 500; transition: color 0.2s;
  }
  .fd406-nav-links a:hover { color: #c98a1a; }
  .fd406-nav-cta {
    background: #1B2A4A; color: #fff; padding: 10px 22px; border-radius: 8px;
    text-decoration: none; font-size: 14px; font-weight: 500; transition: background 0.2s, color 0.2s;
  }
  .fd406-nav-cta:hover { background: #E8A435; color: #1B2A4A; }

  .fd406-nav-toggle {
    display: none; background: none; border: none; cursor: pointer;
    width: 40px; height: 40px; padding: 8px;
    flex-direction: column; justify-content: center; gap: 5px;
  }
  .fd406-nav-toggle span {
    display: block; height: 2px; width: 100%;
    background: #1B2A4A; border-radius: 2px; transition: transform 0.3s, opacity 0.3s;
  }
  .fd406-nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .fd406-nav-toggle.open span:nth-child(2) { opacity: 0; }
  .fd406-nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .fd406-mobile-overlay {
    position: fixed; inset: 0; background: rgba(10,16,30,0.5);
    z-index: 1050; opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .fd406-mobile-overlay.open { opacity: 1; pointer-events: auto; }
  .fd406-mobile-menu {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(78vw, 320px); background: #1B2A4A; z-index: 1100;
    transform: translateX(100%); transition: transform 0.32s cubic-bezier(0.4,0,0.2,1);
    display: flex; flex-direction: column; padding: 90px 32px 32px;
    box-shadow: -20px 0 60px rgba(0,0,0,0.3);
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .fd406-mobile-menu.open { transform: translateX(0); }
  .fd406-mobile-menu a {
    color: rgba(255,255,255,0.85); text-decoration: none; font-size: 18px; font-weight: 500;
    padding: 16px 0; border-bottom: 1px solid rgba(255,255,255,0.1); transition: color 0.2s;
  }
  .fd406-mobile-menu a:hover { color: #E8A435; }
  .fd406-mobile-menu .fd406-mm-cta {
    margin-top: 24px; background: #E8A435; color: #1B2A4A; text-align: center;
    border-radius: 10px; font-weight: 600; padding: 15px; border-bottom: none;
  }
  .fd406-mobile-menu .fd406-mm-cta:hover { background: #fff; color: #1B2A4A; }
  body.fd406-menu-open { overflow: hidden; }

  @media (max-width: 900px) { .fd406-nav { padding: 14px 24px; } }
  @media (max-width: 760px) {
    .fd406-nav-links { display: none; }
    .fd406-nav-toggle { display: flex; }
    .fd406-nav-right .fd406-nav-cta { display: none; }
  }
</style>

<nav class="fd406-nav">
  <a class="fd406-nav-logo" href="/">
    <div class="fd406-nav-logo-mark"><img src="/assets/img/nav-logo.png" width="30" height="18" alt="406 Front Desk Montana logo"></div>
    <div>
      <span class="fd406-nav-logo-text">Front Desk</span>
      <span class="fd406-nav-logo-sub">Always Answering</span>
    </div>
  </a>
  <div class="fd406-nav-right">
    <div class="fd406-nav-links">
      {%- for item in site.nav %}
      <a href="{{ item.url }}">{{ item.label }}</a>
      {%- endfor %}
    </div>
    <a class="fd406-nav-cta" href="/demo/">Try the Demo</a>
    <button class="fd406-nav-toggle" aria-label="Menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </div>
</nav>

<div class="fd406-mobile-overlay"></div>
<div class="fd406-mobile-menu">
  {%- for item in site.nav %}
  <a href="{{ item.url }}">{{ item.label }}</a>
  {%- endfor %}
  <a class="fd406-mm-cta" href="/demo/">Try the Demo</a>
</div>

<script>
  (function () {
    var toggle = document.querySelector('.fd406-nav-toggle');
    var menu = document.querySelector('.fd406-mobile-menu');
    var overlay = document.querySelector('.fd406-mobile-overlay');
    if (!toggle || !menu) return;
    function close() {
      toggle.classList.remove('open'); menu.classList.remove('open');
      if (overlay) overlay.classList.remove('open');
      document.body.classList.remove('fd406-menu-open');
      toggle.setAttribute('aria-expanded', 'false');
    }
    toggle.addEventListener('click', function () {
      var isOpen = menu.classList.toggle('open');
      toggle.classList.toggle('open', isOpen);
      if (overlay) overlay.classList.toggle('open', isOpen);
      document.body.classList.toggle('fd406-menu-open', isOpen);
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
    if (overlay) overlay.addEventListener('click', close);
    menu.querySelectorAll('a').forEach(function (a) { a.addEventListener('click', close); });
  })();
</script>
