<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Hero live-call sequence: ring -> answered -> waveform + transcript -> booked (loops)
  const ringWrap = document.getElementById('ringWrap');
  const answered = document.getElementById('answered');
  const transcript = document.getElementById('transcript');
  const booked = document.getElementById('booked');
  const callTimerEl = document.getElementById('callTimer');
  let callTimers = [], callSecs = 0, callTimerInt = null;

  const convo = [
    { who: 'in',  eyebrow: 'Caller', text: 'Hi, are you taking new clients this week?' },
    { who: 'out', eyebrow: '406 Front Desk', text: 'We are! Thursday 2:30 is open — want it? 📅' },
    { who: 'in',  eyebrow: 'Caller', text: 'Yeah, that works.' },
    { who: 'out', eyebrow: '406 Front Desk', text: 'Perfect — confirmation + reminder on the way. 👍' },
  ];

  function clearCall() { callTimers.forEach(clearTimeout); callTimers = []; if (callTimerInt) clearInterval(callTimerInt); }
  function ct(fn, ms) { callTimers.push(setTimeout(fn, ms)); }
  function callScroll() { transcript.scrollTop = transcript.scrollHeight; }
  function callBubble(item) {
    const d = document.createElement('div');
    d.className = 'bub bub-' + item.who;
    d.innerHTML = '<span class="bub-eyebrow">' + item.eyebrow + '</span>' + item.text;
    transcript.appendChild(d); callScroll();
  }
  function callTyping() {
    const d = document.createElement('div'); d.className = 'typing'; d.id = 'callTyping';
    d.innerHTML = '<span></span><span></span><span></span>'; transcript.appendChild(d); callScroll();
  }
  function killCallTyping() { const x = document.getElementById('callTyping'); if (x) x.remove(); }

  function callRun() {
    clearCall();
    ringWrap.style.display = 'flex';
    answered.style.display = 'none';
    transcript.innerHTML = '';
    booked.style.display = 'none';
    callSecs = 0; callTimerEl.textContent = '0:00';
    ct(() => {
      ringWrap.style.display = 'none';
      answered.style.display = 'flex';
      callTimerInt = setInterval(() => { callSecs++; const m = Math.floor(callSecs / 60); const s = String(callSecs % 60).padStart(2, '0'); callTimerEl.textContent = m + ':' + s; }, 1000);
    }, 1650);
    const base = 2500;
    const beats = [0, 1950, 4050, 5950];
    convo.forEach((item, i) => {
      const at = base + beats[i];
      if (item.who === 'out') { ct(() => { callTyping(); }, at - 800); ct(() => { killCallTyping(); callBubble(item); }, at); }
      else { ct(() => { callBubble(item); }, at); }
    });
    ct(() => { booked.style.display = 'inline-flex'; callScroll(); }, base + 7150);
    ct(callRun, base + 11200);
  }

  if (ringWrap && answered) {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Static end-state (no loop): answered, full transcript, booked shown
      ringWrap.style.display = 'none';
      answered.style.display = 'flex';
      callTimerEl.textContent = '0:12';
      convo.forEach(callBubble);
      booked.style.display = 'inline-flex';
    } else {
      setTimeout(callRun, 600);
    }
  }
</script>
